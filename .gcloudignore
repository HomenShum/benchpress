# Keep Cloud Build context small — only executor/ + daas/ are needed.
.git
.gitignore
.gitattributes

# Local output / caches
node_modules/
**/node_modules/
frontend/dist/
frontend/node_modules/
target/
**/target/
**/__pycache__/
**/*.pyc

# Experiments + results that aren't needed at runtime
experiments/
daas/results/
daas/scaffolds/

# Convex generated (regenerated by codegen, not needed in Docker)
convex/_generated/

# Benchmarks + results directories
benchmarks/
*.sqlite
*.db

# Editor / OS
.vscode/
.idea/
.DS_Store

# Env files
.env
.env.local
.env.*.local

# Packages not needed
packages/
packages-mcp/

# Other large dirs
rust/

# Claude-specific
.claude/
.cursor/
.windsurf/
